# ============================================================
# Environment Variables for ConsensusGraph
# ============================================================
# Copy this file to .env and fill in your credentials.
# A ready-to-use template is available as .env.example:
#   cp .env.example .env

# --- OpenRouter API (Required) ---
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Tavily API (Optional) ---
# Used for web search functionality in the search_agent
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=

# --- Model Configuration (Optional) ---
# Override the default model used for all agent steps.
# Use any OpenRouter-compatible model identifier.
# Default: moonshotai/kimi-k2.6
DEFAULT_MODEL_NAME=moonshotai/kimi-k2.6

# ============================================================
# LangSmith Tracing Configuration
# ============================================================
# LangSmith is LangChain's observability platform for tracing,
# debugging, and monitoring LLM applications.
# Dashboard: https://smith.langchain.com/
# Get your API key from: https://smith.langchain.com/settings

# Enable/disable LangSmith tracing (set to "true" to enable)
LANGSMITH_TRACING=false

# LangSmith API key for authentication
LANGSMITH_API_KEY=

# Project name for organizing traces in the LangSmith dashboard
# Falls back to LANGCHAIN_PROJECT if not set
LANGSMITH_PROJECT=consensusgraph

# Legacy LangChain tracing v2 flag (auto-set when tracing is enabled)
LANGCHAIN_TRACING_V2=true

# Legacy project name fallback (used by older LangChain versions)
LANGCHAIN_PROJECT=consensusgraph

# Run LangChain callbacks in background threads for better performance
LANGCHAIN_CALLBACKS_BACKGROUND=true

# ============================================================
# Notes
# ============================================================
# * Set LANGSMITH_TRACING=true and provide LANGSMITH_API_KEY to
#   enable tracing. All LLM calls will be logged to the dashboard.
# * Leave LANGSMITH_TRACING=false or unset to disable tracing.
# * Traces include prompts, responses, costs, and latency.
# * Tags "langsmith:nostream" and metadata (model, tracing status)
#   are attached automatically by the application.
